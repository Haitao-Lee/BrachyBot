{
  "category": "language",
  "description": "Tests whether BrachyBot matches the user's language in ALL outputs, including tool results.",
  "evaluation": "Check output language matches input language. Tool results must also match.",
  "cases": [
    {
      "id": "LN001",
      "input": "请分析图像",
      "language": "zh",
      "expected_keywords": ["维度", "体素", "扫描", "组织"],
      "forbidden_keywords": ["Dimensions", "Voxel", "Scan"],
      "difficulty": "easy",
      "description": "Chinese input → Chinese analysis output"
    },
    {
      "id": "LN002",
      "input": "analyze the image",
      "language": "en",
      "expected_keywords": ["Dimensions", "Voxel", "Scan"],
      "forbidden_keywords": ["维度", "体素"],
      "difficulty": "easy",
      "description": "English input → English analysis output"
    },
    {
      "id": "LN003",
      "input": "请分割图像",
      "language": "zh",
      "expected_keywords": ["分割", "完成"],
      "forbidden_keywords": ["segmentation completed"],
      "difficulty": "easy",
      "description": "Chinese segmentation → Chinese result"
    },
    {
      "id": "LN004",
      "input": "segment the image",
      "language": "en",
      "expected_keywords": ["segmentation", "completed"],
      "forbidden_keywords": ["分割完成"],
      "difficulty": "easy",
      "description": "English segmentation → English result"
    },
    {
      "id": "LN005",
      "input": "分析并分割图像",
      "language": "zh",
      "expected_keywords": ["分析", "分割"],
      "difficulty": "easy",
      "description": "Chinese multi-step → Chinese output"
    },
    {
      "id": "LN006",
      "input": "analyze and segment",
      "language": "en",
      "expected_keywords": ["Analysis", "Segmentation"],
      "difficulty": "easy",
      "description": "English multi-step → English output"
    },
    {
      "id": "LN007",
      "input": "你好",
      "language": "zh",
      "expected_keywords": ["你好", "BrachyBot"],
      "forbidden_keywords": ["Hello", "Hi"],
      "difficulty": "easy",
      "description": "Chinese greeting → Chinese response"
    },
    {
      "id": "LN008",
      "input": "Hello",
      "language": "en",
      "expected_keywords": ["Hello", "BrachyBot"],
      "forbidden_keywords": ["你好"],
      "difficulty": "easy",
      "description": "English greeting → English response"
    },
    {
      "id": "LN009",
      "input": "帮我查一下前列腺的剂量约束",
      "language": "zh",
      "expected_keywords": ["前列腺", "剂量"],
      "difficulty": "medium",
      "description": "Chinese clinical query → Chinese response"
    },
    {
      "id": "LN010",
      "input": "What are the dose constraints for prostate brachytherapy?",
      "language": "en",
      "expected_keywords": ["prostate", "dose", "Gy"],
      "forbidden_keywords": ["前列腺"],
      "difficulty": "medium",
      "description": "English clinical query → English response"
    },
    {
      "id": "LN011",
      "input": "分析图像然后分割",
      "language": "zh",
      "expected_keywords": ["分析", "分割"],
      "forbidden_keywords": ["Analysis", "Segmentation"],
      "difficulty": "medium",
      "description": "Chinese multi-action → Chinese output"
    },
    {
      "id": "LN012",
      "input": "请帮我切换到viewer",
      "language": "zh",
      "expected_keywords": ["viewer", "切换"],
      "difficulty": "medium",
      "description": "UI action in Chinese"
    },
    {
      "id": "LN013",
      "input": "帮我分割这个CT，然后告诉我结果",
      "language": "zh",
      "expected_keywords": ["分割", "完成"],
      "difficulty": "medium",
      "description": "Segmentation request with follow-up — both in Chinese"
    },
    {
      "id": "LN014",
      "input": "calculate the dose and tell me the D90",
      "language": "en",
      "expected_keywords": ["dose", "D90"],
      "difficulty": "medium",
      "description": "English dose query"
    },
    {
      "id": "LN015",
      "input": "这个图像的HU值范围是多少",
      "language": "zh",
      "expected_keywords": ["HU", "范围"],
      "difficulty": "easy",
      "description": "Chinese HU query"
    }
  ]
}
