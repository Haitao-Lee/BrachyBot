{
  "category": "tool_calling",
  "description": "Tests whether BrachyBot calls the correct tool(s) for each user request. Not knowledge — system capability.",
  "evaluation": "Check which tools were called. Order matters for multi-step. Language must match input.",
  "cases": [
    {
      "id": "TC001",
      "input": "请分析图像",
      "language": "zh",
      "expected_tools": [
        "code_executor"
      ],
      "forbidden_tools": [
        "ctv_segmentation",
        "oar_segmentation"
      ],
      "difficulty": "easy",
      "description": "Analysis should use code_executor, NOT segmentation tools"
    },
    {
      "id": "TC002",
      "input": "analyze the image",
      "language": "en",
      "expected_tools": [
        "code_executor"
      ],
      "forbidden_tools": [
        "ctv_segmentation",
        "oar_segmentation"
      ],
      "difficulty": "easy",
      "description": "English analysis request"
    },
    {
      "id": "TC003",
      "input": "请分割图像",
      "language": "zh",
      "expected_tools": [
        "ctv_segmentation",
        "oar_segmentation"
      ],
      "forbidden_tools": [
        "code_executor"
      ],
      "difficulty": "easy",
      "description": "Segmentation should call both CTV and OAR tools"
    },
    {
      "id": "TC004",
      "input": "帮我分割",
      "language": "zh",
      "expected_tools": [
        "ctv_segmentation",
        "oar_segmentation"
      ],
      "difficulty": "easy",
      "description": "Casual segmentation request"
    },
    {
      "id": "TC005",
      "input": "segment the CT",
      "language": "en",
      "expected_tools": [
        "ctv_segmentation",
        "oar_segmentation"
