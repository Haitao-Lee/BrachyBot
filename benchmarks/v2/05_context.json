{
  "category": "context",
  "description": "Tests whether BrachyBot maintains context across multiple conversation turns.",
  "evaluation": "Multi-turn conversations. Later turns should reference earlier context.",
  "cases": [
    {
      "id": "CT001",
      "type": "multi_turn",
      "description": "Segmentation context: user segments, then asks about results",
      "turns": [
        {"input": "帮我分割图像", "expected_tools": ["ctv_segmentation", "oar_segmentation"]},
        {"input": "分割了多少个器官？", "expected_keywords": ["57", "器官"], "difficulty": "medium"}
      ]
    },
    {
      "id": "CT002",
      "type": "multi_turn",
      "description": "Analysis context: user analyzes, then asks about specific metric",
      "turns": [
        {"input": "分析图像", "expected_tools": ["code_executor"]},
        {"input": "HU范围是多少？", "expected_keywords": ["-1000", "1498"], "difficulty": "medium"}
      ]
    },
    {
      "id": "CT003",
      "type": "multi_turn",
      "description": "UI context: user adjusts window, then adjusts again",
      "turns": [
        {"input": "把窗宽调到400", "expected_tools": ["ui_controller"]},
        {"input": "再调低一点", "expected_tools": ["ui_controller"], "difficulty": "medium"}
      ]
    },
    {
      "id": "CT004",
      "type": "multi_turn",
      "description": "Multi-step context: user does analysis+segmentation, then asks about CTV",
      "turns": [
        {"input": "分析并分割图像", "expected_tools": ["code_executor", "ctv_segmentation", "oar_segmentation"]},
        {"input": "CTV的体积是多少？", "expected_keywords": ["mm³", "cm³"], "difficulty": "medium"}
      ]
    },
    {
      "id": "CT005",
      "type": "multi_turn",
      "description": "Panel switch context: user switches to viewer, then interacts",
      "turns": [
        {"input": "帮我切到viewer", "expected_tools": ["ui_controller"]},
        {"input": "显示CTV overlay", "expected_tools": ["ui_controller"], "difficulty": "medium"}
      ]
    },
    {
      "id": "CT006",
      "type": "multi_turn",
      "description": "Error recovery context: tool fails, user asks to retry",
      "turns": [
        {"input": "分割图像", "expected_tools": ["ctv_segmentation", "oar_segmentation"]},
        {"input": "CTV分割结果不对，重新分割", "expected_tools": ["ctv_segmentation"], "difficulty": "hard"}
      ]
    },
    {
      "id": "CT007",
      "type": "multi_turn",
      "description": "Clinical context: user queries dose, then asks about constraint",
      "turns": [
        {"input": "前列腺癌I-125的处方剂量是多少？", "expected_keywords": ["145", "Gy"]},
        {"input": "那膀胱的剂量约束呢？", "expected_keywords": ["膀胱", "剂量"], "difficulty": "medium"}
      ]
    },
    {
      "id": "CT008",
      "type": "multi_turn",
      "description": "Language consistency across turns",
      "turns": [
        {"input": "请分析图像", "language": "zh", "expected_keywords": ["分析"]},
        {"input": "再帮我分割一下", "language": "zh", "expected_keywords": ["分割"], "difficulty": "medium"}
      ]
    },
    {
      "id": "CT009",
      "type": "multi_turn",
      "description": "English multi-turn context",
      "turns": [
        {"input": "analyze the image", "language": "en", "expected_tools": ["code_executor"]},
        {"input": "now segment it", "language": "en", "expected_tools": ["ctv_segmentation", "oar_segmentation"], "difficulty": "medium"}
      ]
    },
    {
      "id": "CT010",
      "type": "multi_turn",
      "description": "User corrects the bot",
      "turns": [
        {"input": "分割图像", "expected_tools": ["ctv_segmentation", "oar_segmentation"]},
        {"input": "不对，我要的是OAR分割，不是CTV", "expected_tools": ["oar_segmentation"], "difficulty": "hard"}
      ]
    },
    {
      "id": "CT011",
      "type": "multi_turn",
      "description": "Sequential workflow with context",
      "turns": [
        {"input": "分析图像", "expected_tools": ["code_executor"]},
        {"input": "分割", "expected_tools": ["ctv_segmentation", "oar_segmentation"]},
        {"input": "切到viewer", "expected_tools": ["ui_controller"], "difficulty": "hard"}
      ]
    },
    {
      "id": "CT012",
      "type": "multi_turn",
      "description": "User asks about previous result",
      "turns": [
        {"input": "帮我查一下前列腺癌的剂量约束", "expected_tools": ["clinical_kb"]},
        {"input": "刚才查到的D90是多少？", "expected_keywords": ["D90", "Gy"], "difficulty": "medium"}
      ]
    },
    {
      "id": "CT013",
      "type": "multi_turn",
      "description": "User gives feedback on segmentation",
      "turns": [
        {"input": "分割图像", "expected_tools": ["ctv_segmentation", "oar_segmentation"]},
        {"input": "分割结果看起来不错，帮我做个3D重建", "expected_tools": ["ui_controller"], "difficulty": "medium"}
      ]
    },
    {
      "id": "CT014",
      "type": "multi_turn",
      "description": "User adjusts settings then checks result",
      "turns": [
        {"input": "把窗宽调到200", "expected_tools": ["ui_controller"]},
        {"input": "现在看起来怎么样？", "difficulty": "easy"}
      ]
    },
    {
      "id": "CT015",
      "type": "multi_turn",
      "description": "Context across language switch (edge case)",
      "turns": [
        {"input": "分析图像", "language": "zh", "expected_tools": ["code_executor"]},
        {"input": "now segment it", "language": "en", "expected_tools": ["ctv_segmentation", "oar_segmentation"], "difficulty": "hard"}
      ]
    }
  ]
}
