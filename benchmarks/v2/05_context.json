{
  "category": "context",
  "description": "Tests whether BrachyBot maintains context across multiple conversation turns.",
  "evaluation": "Multi-turn conversations. Later turns should reference earlier context.",
  "cases": [
    {
      "id": "CT001",
      "type": "multi_turn",
      "description": "Segmentation context: user segments, then asks about results",
      "turns": [
        {
          "input": "帮我分割图像",
          "expected_tools": [
            "ctv_segmentation",
            "oar_segmentation"
          ],
          "language": "zh",
          "context": "CT已加载"
        },
        {
          "input": "分割了多少个器官？",
          "expected_keywords": [
            "器官",
            "organ"
          ],
          "difficulty": "medium",
          "forbidden_keywords": [],
          "language": "zh",
          "context": "CT已加载"
        }
      ]
    },
    {
      "id": "CT002",
      "type": "multi_turn",
      "description": "Analysis context: user analyzes, then asks about specific metric",
      "turns": [
        {
          "input": "分析图像",
          "expected_tools": [
            "code_executor"
          ],
          "language": "zh",
          "context": "CT已加载"
        },
        {
          "input": "HU范围是多少？",
          "expected_keywords": [
            "HU"
          ],
          "difficulty": "medium",
          "language": "zh",
          "context": "CT已加载"
        }
      ]
    },
    {
      "id": "CT003",
      "type": "multi_turn",
      "description": "UI context: user adjusts window, then adjusts again",
      "turns": [
        {
          "input": "把窗宽调到400",
          "expected_tools": [
            "ui_controller"
          ],
          "language": "zh",
          "context": "CT已加载"
        },
        {
          "input": "再调低一点",
          "expected_tools": [
            "ui_controller"
          ],
          "difficulty": "medium",
          "language": "zh",
          "context": "CT已加载"
        }
      ]
    },
    {
      "id": "CT004",
      "type": "multi_turn",
      "description": "Multi-step context: user does analysis+segmentation, then asks about CTV",
      "turns": [
        {
          "input": "分析并分割图像",
          "expected_tools": [
            "code_executor",
            "ctv_segmentation",
            "oar_segmentation"
          ],
          "language": "zh",
          "context": "CT已加载"
        },
        {
          "input": "CTV的体积是多少？",
          "expected_keywords": [
            "CTV",
            "体积",
            "mm",
            "cm"
          ],
          "difficulty": "medium",
          "language": "zh",
          "context": "CT已加载"
        }
      ]
    },
    {
      "id": "CT005",
      "type": "multi_turn",
      "description": "Panel switch context: user switches to viewer, then interacts",
      "turns": [
        {
          "input": "帮我切到viewer",
          "expected_tools": [
            "ui_controller"
          ],
          "language": "zh",
          "context": "CT已加载"
        },
        {
          "input": "显示CTV overlay",
          "expected_tools": [
            "ui_controller"
          ],
          "difficulty": "medium",
          "language": "zh",
          "context": "CT已加载"
        }
      ]
    },
    {
      "id": "CT006",
      "type": "multi_turn",
      "description": "Error recovery context: tool fails, user asks to retry",
      "turns": [
        {
          "input": "分割图像",
          "expected_tools": [
            "ctv_segmentation",
            "oar_segmentation"
          ],
          "language": "zh",
          "context": "CT已加载"
        },
        {
          "input": "CTV分割结果不对，重新分割",
          "expected_tools": [
            "ctv_segmentation"
          ],
          "difficulty": "hard",
          "language": "zh",
          "context": "CT已加载"
        }
      ]
    },
    {
      "id": "CT008",
      "type": "multi_turn",
      "description": "Language consistency across turns",
      "turns": [
        {
          "input": "请分析图像",
          "language": "zh",
          "expected_keywords": [
            "分析"
          ],
          "context": "CT已加载"
        },
        {
          "input": "再帮我分割一下",
          "language": "zh",
          "expected_keywords": [
            "分割"
          ],
          "difficulty": "medium",
          "context": "CT已加载"
        }
      ]
    },
