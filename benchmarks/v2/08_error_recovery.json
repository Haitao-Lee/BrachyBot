{
  "category": "error_recovery",
  "description": "Tests whether BrachyBot handles errors gracefully and recovers appropriately.",
  "evaluation": "Bot should report errors clearly, not crash, and suggest alternatives.",
  "cases": [
    {
      "id": "ER001",
      "input": "分割一个不存在的文件 /tmp/fake.nii",
      "language": "zh",
      "expected_behavior": "Should report file not found, not crash",
      "difficulty": "medium",
      "description": "File not found — should handle gracefully",
      "expected_keywords": [
